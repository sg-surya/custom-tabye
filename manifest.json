{
  "manifest_version": 3,
  "name": "Vasudev AI New Tab",
  "description": "A premium, minimal, Apple-style new tab dashboard by Vasudev AI.",
  "version": "1.1",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://api.openweathermap.org/*"
  ]
}
